# ── Database (Supabase PostgreSQL) ─────────────────────────
# Connection pooler URL (used by Prisma at runtime — pgBouncer)
DATABASE_URL="postgresql://postgres.knmchdgzgnawhqhjwits:[DB_PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection URL (used by Prisma for migrations)
DIRECT_URL="postgresql://postgres:[DB_PASSWORD]@db.knmchdgzgnawhqhjwits.supabase.co:5432/postgres"

# ── Supabase ────────────────────────────────────────────────
SUPABASE_URL="https://knmchdgzgnawhqhjwits.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# ── JWT ─────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
JWT_EXPIRES_IN="7d"

# ── Server ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN="http://localhost:5173"

# ── Supabase Storage ────────────────────────────────────────
SUPABASE_STORAGE_BUCKET="spare-parts-images"

# ── LINE Notify (Phase 8) ───────────────────────────────────
LINE_NOTIFY_TOKEN=""

# ── Email / Nodemailer (Phase 8) ────────────────────────────
SMTP_HOST=""
